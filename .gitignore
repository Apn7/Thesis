# =============================================================================
#  .gitignore — Smart Cane Flutter companion app
#  Repo root: Test_app/test_app_1/  (remote: Apn7/Thesis.git)
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment
# -----------------------------------------------------------------------------
.env
*.env.local
# Keep:
!.env.example

# -----------------------------------------------------------------------------
# Flutter / Dart / Pub
# -----------------------------------------------------------------------------
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.metadata
.packages
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication / obfuscation
app.*.symbols
app.*.map.json

# Android build outputs
/android/app/debug
/android/app/profile
/android/app/release
/android/.gradle/
/android/local.properties
/android/key.properties
**/*.keystore
**/*.jks
**/GeneratedPluginRegistrant.java

# iOS / macOS
/ios/Pods/
/ios/.symlinks/
/ios/Flutter/App.framework
/ios/Flutter/Flutter.framework
/ios/Flutter/Flutter.podspec
/ios/Flutter/Generated.xcconfig
/ios/Flutter/ephemeral/
/ios/Flutter/flutter_export_environment.sh
/ios/Flutter/app.flx
/ios/Flutter/app.zip
/ios/Flutter/flutter_assets/
/ios/Runner/GeneratedPluginRegistrant.*
/macos/Pods/
/macos/Flutter/ephemeral/

# Desktop platform ephemeral
/windows/flutter/ephemeral/
/linux/flutter/ephemeral/

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------
*.iml
*.ipr
*.iws
.idea/
# .vscode is intentionally kept tracked — launch.json is useful for debug
# configuration. If you have user-specific settings, add only those files here.

# -----------------------------------------------------------------------------
# Logs / misc artifacts
# -----------------------------------------------------------------------------
*.class
*.log
*.swp
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# -----------------------------------------------------------------------------
# Python (for the YOLO export workflow and any other Python scripts)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.Python
.venv/
.venv-*/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# YOLO / ML export pipeline junk (Test_app/test_app_1 project root)
# Generated by export_yolo_models.py + Ultralytics; can be huge (multi-GB).
# Keep the small shipped TFLite files under assets/models/ (whitelisted below).
# -----------------------------------------------------------------------------
/.venv-export/
/datasets/
/yolo11n_saved_model/
/yolo11n.pt
/yolo11n.onnx
/yolo11n.torchscript
/pip-tmp/

# -----------------------------------------------------------------------------
# Model assets — IGNORE big runtime model files, KEEP small shipped ones
# -----------------------------------------------------------------------------
# Ignore the huge Gemma LLM and all sherpa-onnx model directories
assets/models/gemma-*.litertlm
assets/models/sherpa-onnx-*/

# Generic large-model glob safety net (.bin / .onnx anywhere under assets/models)
assets/models/**/*.bin
assets/models/**/*.onnx

# Explicit keep-list (Git's last-match-wins resolves these even if a broader
# pattern above matched). These files MUST stay tracked:
!assets/models/coco_labels.txt
!assets/models/README.md
!assets/models/yolo11n_float16.tflite
!assets/models/yolo11n_int8.tflite

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# AI Agents / tooling
# -----------------------------------------------------------------------------
.agents/
.agent/
.claude/settings.local.json
